    %% ===== LAYER 0: INTERNET ENTRY POINT =====
    subgraph internet["🌐 Tráfico Externo"]
        direction LR
        users["🌐 Internet Traffic<br/>External Requests"]
    end

    %% ===== LAYER 1: ENTRY / SECURITY =====
    subgraph entry["📥 Entrada y Seguridad de Borde"]
        direction LR
        cdn["🌐 CloudFront<br/>CDN / Edge"]
        waf["🔐 WAF<br/>Web ACL"]
    end

    %% ===== LAYER 2: LOAD BALANCING =====
    subgraph lb_layer["⚖️ Balanceo de Carga"]
        direction LR
        alb["⚖️ ALB<br/>Traffic Distribution"]
    end

    %% ===== LAYER 3: COMPUTE =====
    subgraph compute_layer["⚙️ Cómputo"]
        direction LR
        ecs["⚙️ ECS Service<br/>App Containers"]
    end

    %% ===== LAYER 4: STORAGE / PERSISTENCE =====
    subgraph storage_layer["💾 Almacenamiento y Persistencia"]
        direction LR
        rds["🗄️ RDS<br/>Database"]
        s3["🪣 S3<br/>Static Assets"]
    end

    %% ===== LAYER 5: MONITORING =====
    subgraph monitoring_layer["📝 Observabilidad"]
        direction LR
        cw["📝 CloudWatch<br/>Logs & Metrics"]
    end

    %% ===== CONNECTIONS =====
    users --> cdn
    cdn --> waf
    cdn --> s3
    cdn --> alb
    alb --> ecs
    ecs --> rds
    ecs --> cw

    %% ===== CLASS ASSIGNMENTS =====
    class users external
    class cdn network
    class waf iam
    class alb network
    class ecs compute
    class rds database
    class s3 storage
    class cw monitoring
